# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.

# Required
XAI_API_KEY=your_xai_api_key_here

# Dashboard access codes (optional — defaults shown below if omitted)
ACCESS_CODE=1001
FLAGSHIP_CODE=flagship2026

# Email alerts (Resend API is preferred for production)
RESEND_API_KEY=your_resend_api_key_here
EMAIL_SENDER=you@example.com
EMAIL_RECIPIENT=recipient@example.com

# SMTP fallback (local development only; cloud hosts block SMTP ports)
EMAIL_PASSWORD=your_gmail_app_password_here
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=465

# Database path (override for persistent cloud volumes, e.g. /data/opdivo_reports.db)
DB_PATH=opdivo_reports.db
